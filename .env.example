# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_BOT_LOGIN=pr-precedent-ai[bot]

# Supermemory Local (npx supermemory local — see docs/SETUP.md §2)
SUPERMEMORY_BASE_URL=http://localhost:6767
SUPERMEMORY_API_KEY=

# Surfacing
CONFIDENCE_THRESHOLD=0.78
SURFACING_MODE=comment
# The 25-case benchmark currently keeps the proven raw-file profile in production.
RETRIEVAL_PROFILE_ID=raw-file-baseline
RETRIEVAL_QUERY_VARIANT=raw-file
RETRIEVAL_RERANK=false
RETRIEVAL_REWRITE_QUERY=false
RETRIEVAL_ONLY_MATCHING_CHUNKS=true
# Set after schema-v2 backfill is verified. Leave empty for legacy compatibility.
RETRIEVAL_SCHEMA_VERSION=
RETRIEVAL_RESULT_LIMIT=5
RETRIEVAL_AMBIGUITY_MARGIN=0.02

# Read-only dashboard allowlist (comma separated, fail-closed when empty)
DASHBOARD_REPOSITORIES=owner/repo

# Accuracy tooling
FINAL_CONTEXT_LINES=8
SUPERMEMORY_PROCESSING_POLL_MS=2000

# Server
PORT=3000
