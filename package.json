{
  "name": "pr-precedent",
  "version": "1.0.0",
  "description": "Captures resolved code review discussions at PR merge and surfaces relevant past decisions as a bot comment on similar new PRs.",
  "main": "dist/index.js",
  "private": true,
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "cli": "tsx src/cli/index.ts",
    "test": "vitest run",
    "smoke:github": "tsx scripts/smoke-test-github.ts",
    "smoke:supermemory": "tsx scripts/smoke-test-supermemory.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smxone/pr-precedent.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/smxone/pr-precedent/issues"
  },
  "homepage": "https://github.com/smxone/pr-precedent#readme",
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^26.1.1",
    "pm2": "^7.0.3",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks": "^14.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "supermemory": "^4.24.12"
  }
}
